---
import Layout from '../layouts/Layout.astro';
import ProjectSection from '@/components/ProjectSection';
---

<Layout>
  <div class="w-full overflow-x-hidden px-8 md:px-0">
    <div class="relative flex flex-col items-center w-full min-h-screen pt-12">
      <div class="w-full max-w-[1024px]">
        <a href="/" class="mb-8 inline-block transition-colors text-xs font-mono" style="color: var(--fg-muted);" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">&larr; back</a>
        <ProjectSection client:load />
      </div>
    </div>
  </div>
</Layout>
