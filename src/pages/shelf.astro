---
import Layout from '../layouts/Layout.astro';
import currentRead from '../data/current_read.json';
import pastRead from '../data/past_read.json';

const totalItems = currentRead.length + pastRead.length;
---

<Layout>
  <div class="w-full overflow-x-hidden px-4 md:px-8 min-h-screen py-12 flex justify-center">
    
    <!-- The Book Page Container -->
    <div class="w-full max-w-[750px] relative px-8 py-16 md:px-16 border border-[#e5e4df] rounded-sm bg-[#FAF9F6] shadow-sm">
      
      <a href="/" class="text-[#8c8c8c] hover:text-[#222] mb-12 inline-block transition-colors font-sans text-sm tracking-wide">&larr; Back to Home</a>
      
      <div class="mb-16">
        <h1 class="text-4xl font-serif font-medium text-[#222] mb-2 tracking-tight">My Shelf</h1>
        <p class="text-[#555] font-serif italic text-lg">A catalog of {totalItems} items I'm reading or have read.</p>
      </div>

      <div class="font-serif text-[#222] text-lg leading-relaxed space-y-16">
        <!-- Currently Reading Section -->
        {currentRead.length > 0 && (
          <div>
            <h2 class="text-2xl mb-6 font-bold tracking-tight text-[#111] uppercase text-sm tracking-widest border-b border-[#e5e4df] pb-2">Currently Reading</h2>
            <ul class="list-disc pl-5 space-y-3 marker:text-[#999]">
              {currentRead.map((item) => (
                <li class="pl-2">
                  <a href={item.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 transition-colors underline decoration-[#d4d4d4] underline-offset-4 hover:decoration-blue-600">
                    {item.name}
                  </a>
                  {item.author && <span class="text-[#666] text-base ml-1">— {item.author}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Past Reads Section -->
        {pastRead.length > 0 && (
          <div>
            <h2 class="text-2xl mb-6 font-bold tracking-tight text-[#111] uppercase text-sm tracking-widest border-b border-[#e5e4df] pb-2">Past Reads</h2>
            <ul class="list-disc pl-5 space-y-3 marker:text-[#999]">
              {pastRead.map((item) => (
                <li class="pl-2">
                  <a href={item.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 transition-colors underline decoration-[#d4d4d4] underline-offset-4 hover:decoration-blue-600">
                    {item.name}
                  </a>
                  {item.author && <span class="text-[#666] text-base ml-1">— {item.author}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

    </div>
  </div>
</Layout>
