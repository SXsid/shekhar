---
import Layout from '../layouts/Layout.astro';
import currentRead from '../data/current_read.json';
import pastRead from '../data/past_read.json';

const totalItems = currentRead.length + pastRead.length;
---

<Layout>
  <div class="w-full px-5 md:px-8 min-h-screen py-10 flex justify-center">
    <div class="w-full max-w-[640px]">

      <a
        href="/"
        class="inline-block mb-10 text-xs tracking-wide transition-colors font-ui"
        style="color: var(--fg-sub); font-family: 'Inter', sans-serif;"
        onmouseover="this.style.color='var(--fg)'"
        onmouseout="this.style.color='var(--fg-sub)'"
      >
        ← back
      </a>

      <div class="mb-10">
        <h1 class="text-2xl font-semibold mb-1" style="color: var(--fg); font-family: ui-serif, Georgia, serif;">
          My Shelf
        </h1>
        <p class="text-sm italic" style="color: var(--fg-muted); font-family: ui-serif, Georgia, serif;">
          {totalItems} books I'm reading or have read.
        </p>
      </div>

      <div class="space-y-10">

        {currentRead.length > 0 && (
          <section>
            <h2
              class="text-xs mb-4 font-semibold uppercase tracking-widest pb-2"
              style="color: var(--fg-sub); border-bottom: 1px solid var(--border); font-family: 'Inter', sans-serif;"
            >
              Currently Reading
            </h2>
            <ul class="space-y-3" style="list-style: none; padding: 0;">
              {currentRead.map((item) => (
                <li class="flex items-baseline gap-2">
                  <span style="color: var(--fg-sub); font-size: 0.75rem;">—</span>
                  <div>
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="transition-colors"
                      style="color: var(--fg); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px;"
                      onmouseover="this.style.textDecorationColor='var(--accent)'; this.style.color='var(--accent)'"
                      onmouseout="this.style.textDecorationColor='var(--border)'; this.style.color='var(--fg)'"
                    >
                      {item.name}
                    </a>
                    {item.author && (
                      <span class="text-sm ml-2" style="color: var(--fg-sub);">
                        {item.author}
                      </span>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        )}

        {pastRead.length > 0 && (
          <section>
            <h2
              class="text-xs mb-4 font-semibold uppercase tracking-widest pb-2"
              style="color: var(--fg-sub); border-bottom: 1px solid var(--border); font-family: 'Inter', sans-serif;"
            >
              Past Reads
            </h2>
            <ul class="space-y-3" style="list-style: none; padding: 0;">
              {pastRead.map((item) => (
                <li class="flex items-baseline gap-2">
                  <span style="color: var(--fg-sub); font-size: 0.75rem;">—</span>
                  <div>
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="transition-colors"
                      style="color: var(--fg-muted); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px;"
                      onmouseover="this.style.color='var(--fg)'; this.style.textDecorationColor='var(--fg-muted)'"
                      onmouseout="this.style.color='var(--fg-muted)'; this.style.textDecorationColor='var(--border)'"
                    >
                      {item.name}
                    </a>
                    {item.author && (
                      <span class="text-sm ml-2" style="color: var(--fg-sub);">
                        {item.author}
                      </span>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        )}

      </div>
    </div>
  </div>
</Layout>
