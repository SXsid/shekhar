---
import Layout from '../layouts/Layout.astro';
import HeroBanner from "@/components/HeroSection/HeroBanner";
import ProfileHeader from "@/components/HeroSection/ProfileHeader";
import Bio from "@/components/HeroSection/Bio";
import CTASection from "@/components/HeroSection/CTASection";
import Socials from "@/components/HeroSection/Socials";
import Git from "@/components/GithhubSection/Git";
import Qoute from "@/components/Qoute";
import ExpSection from "@/components/ExpSection/ExpSection";
import Footer from "@/components/footer/Footer";

const AVATAR_SIZE = 76;
const HANG = 36;
---

<Layout>
  <div class="w-full overflow-x-hidden px-4 md:px-0">
    <div class="relative flex flex-col items-center w-full">

      <!-- Main container matching the 800px width limit -->
      <div class="flex flex-col items-center pb-24 w-full max-w-[800px] min-w-0 mt-6 md:mt-10">
        
        <!-- 1. Standalone Banner Wrapper (overflow visible for avatar overlay) -->
        <div class="relative w-full overflow-visible mb-6">
          <HeroBanner client:load />

          {/* Overlapping Avatar sitting between banner and content card */}
          <div
            class="absolute"
            style={`bottom: -${HANG}px; left: 20px; z-index: 20;`}
          >
            <img
              src="https://i.ibb.co/spWbbdZM/Screenshot-from-2025-12-23-03-19-13.png"
              alt="Sudhanshu Shekhar"
              style={`width: ${AVATAR_SIZE}px; height: ${AVATAR_SIZE}px; border-radius: 12px; object-fit: cover; display: block; border: 3px solid var(--bg-card); box-shadow: 0 0 0 1px var(--border);`}
            />
          </div>
        </div>

        <!-- 2. Main Top Level Content Container (modular parts inside) -->
        <div
          class="w-full rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] px-5 pb-8 min-w-0 overflow-hidden"
          style={`padding-top: ${HANG + 18}px;`}
        >
          {/* Profile Header (Name, username, resume) */}
          <div class="mb-4">
            <ProfileHeader client:load />
          </div>

          {/* About / Bio */}
          <div class="mb-4">
            <Bio client:load />
          </div>

          {/* Schedule call & Mail CTA */}
          <div class="mb-6">
            <CTASection client:load />
          </div>

          {/* Socials / Links */}
          <div class="mb-6">
            <Socials client:load />
          </div>

          <!-- Divider line before Git contributions -->
          <div class="w-full h-[1px] bg-[var(--border)] my-8"></div>

          {/* Git Contributions Calendar */}
          <div class="w-full mb-2">
            <Git client:only="react" />
          </div>

          <!-- Divider line before Experience section -->
          <!-- <div class="w-full h-[1px] bg-[var(--border)] my-8"></div> -->

          {/* Experience Section */}
          <div class="w-full mb-2">
            <ExpSection client:load />
          </div>

          <!-- Divider line before Quote -->
          <div class="w-full h-[1px] bg-[var(--border)] my-8"></div>

          {/* Quote */}
          <div class="w-full">
            <Qoute client:load />
          </div>
        </div>

      </div>

      <!-- Footer -->
      <div class="w-full">
        <Footer client:load />
      </div>


    </div>
  </div>
</Layout>
