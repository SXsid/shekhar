---
import Layout from '../layouts/Layout.astro';
import About from "@/components/AboutSection/About";
import HiringBanner from "@/components/Banner/Banner";
import Git from "@/components/GithhubSection/Git";
import Hero from "@/components/HeroSection/Hero";
import Qoute from "@/components/Qoute";
import SkillSection from "@/components/Skill/SkillSection";
import Nav from "@/components/AboutSection/Nav";
import { FloatingDock } from "@/components/FloatingDoc";
import Footer from "@/components/footer/Footer";

// Note: Ensure your components have "client:load" where interactivity is required.
---

<Layout>
  <div class="w-full overflow-x-hidden px-8 md:px-0">
    {/* Page wrapper */}
    <div class="relative flex flex-col items-center w-full">
      <div class="flex flex-col md:gap-2 gap-2 items-center pb-24 w-full max-w-[1024px]">
        <Hero client:load />
        <About client:load />
        <Nav client:load />
        <Git client:only="react" />
        <SkillSection client:load />
        <Qoute client:load />
      </div>

      <div class="relative z-10 w-full">
        <Footer client:load />
      </div>

      <div class="fixed bottom-15 md:bottom-15 left-0 right-0 flex justify-center items-center z-50 pointer-events-none">
        <div class="pointer-events-auto">
          <FloatingDock client:load />
        </div>
      </div>
    </div>
  </div>
</Layout>
