---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout>
  <div class="w-full overflow-x-hidden px-8 md:px-0">
    <div class="relative flex flex-col items-center w-full min-h-screen pt-24 pb-24">
      <div class="w-full max-w-[800px] prose prose-invert prose-p:text-neutral-600 prose-headings:text-[#333333]">
        <a href="/blogs" class="text-neutral-500 hover:text-[#333333] mb-8 inline-block transition-colors no-underline">&larr; Back to Blogs</a>
        
        <h1 class="text-4xl font-bold mb-4">{entry.data.title}</h1>
        <div class="flex gap-4 text-sm text-neutral-500 mb-8">
          <span>{entry.data.dateOfPublish}</span>
          <span>&bull;</span>
          <span>{entry.data.topic}</span>
        </div>
        
        <article class="mt-8 markdown-body text-neutral-800 leading-relaxed space-y-4 text-lg">
          <Content />
        </article>
      </div>
    </div>
  </div>
</Layout>
