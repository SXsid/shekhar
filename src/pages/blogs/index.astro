---
import Layout from '../../layouts/Layout.astro';
import Intro from '@/components/Intro/Intro';
import BlogCard from '@/components/card/BlogCard';
import { getCollection } from 'astro:content';

const blogs = await getCollection('blog');
---

<Layout>
  <div class="w-full overflow-x-hidden px-8 md:px-0">
    <div class="relative flex flex-col items-center w-full min-h-screen pt-12">
      <div class="w-full max-w-[1024px]">
        <a href="/" class="text-neutral-500 hover:text-[#333333] mb-8 inline-block transition-colors">&larr; Back to Home</a>
        
        <div class="flex flex-col items-center mt-6">
          <Intro
            client:load
            title="Blogs"
            desc="A collection of my blogs where I share experiences and ideas on technology, programming languages, databases, cloud and frameworks"
          />
          <div class="flex flex-col justify-center items-center mt-6 gap-3 w-full">
            {blogs.map((blog) => (
              <BlogCard
                client:load
                title={blog.data.title}
                dateOfpublish={blog.data.dateOfPublish}
                link={`/blogs/${blog.slug}`}
                topic={blog.data.topic || 'General'}
                color={blog.data.color}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
