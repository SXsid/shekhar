---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '@/components/card/BlogCard';
import { getCollection } from 'astro:content';

const blogs = await getCollection('blog');
---

<Layout>
  <div class="w-full overflow-x-hidden px-4 md:px-0">
    <div class="relative flex flex-col items-center w-full min-h-screen pt-10 pb-28">
      <div class="w-full max-w-[800px] px-2 md:px-0">

        <a
          href="/"
          class="inline-block mb-8 text-xs font-mono transition-colors"
          style="color: var(--fg-muted);"
          onmouseover="this.style.color='var(--fg)'"
          onmouseout="this.style.color='var(--fg-muted)'"
        >
          &larr; back
        </a>

        <div class="flex items-center justify-between mb-1">
          <h1 class="text-2xl font-semibold" style="color: var(--fg);">Blogs</h1>
          <a
            href="/rss.xml"
            target="_blank"
            class="text-[11px] font-mono border border-[var(--border)] rounded px-2 py-0.5 transition-colors flex items-center gap-1"
            style="color: var(--fg-sub); background: var(--bg-hover); text-decoration: none;"
            onmouseover="this.style.color='var(--fg)'; this.style.borderColor='var(--fg-sub)'"
            onmouseout="this.style.color='var(--fg-sub)'; this.style.borderColor='var(--border)'"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="inline"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
            RSS Feed
          </a>
        </div>
        <p class="text-sm mb-8" style="color: var(--fg-muted);">
          Writing on systems, infrastructure, and things I find interesting.
        </p>

        <!-- Content-driven blogs (markdown files) -->
        {blogs.length > 0 && (
          <div class="flex flex-col divide-y" style="border-color: var(--border);">
            {blogs.map((blog) => (
              <BlogCard
                client:load
                title={blog.data.title}
                dateOfpublish={blog.data.dateOfPublish}
                link={`/blogs/${blog.slug}`}
                topic={blog.data.topic || 'General'}
                color={blog.data.color}
              />
            ))}
          </div>
        )}

      </div>
    </div>
  </div>
</Layout>
