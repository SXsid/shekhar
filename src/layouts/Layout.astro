---
import { ClientRouter } from 'astro:transitions';
import '@/styles/globals.css';
import { FloatingDock } from '@/components/FloatingDoc';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Backend-focused Full Stack Developer experienced in building scalable systems, APIs, and DevOps workflows." />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="https://i.ibb.co/spWbbdZM/Screenshot-from-2025-12-23-03-19-13.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Shekhar — Backend & Infrastructure Engineer</title>

    <!-- Fonts: Inter for UI + JetBrains Mono for code -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!--
      Theme init — MUST run before first paint (no-flash).
      Also wired to astro:after-swap so client-side navigation
      never loses the .dark class.
    -->
    <script is:inline>
      function __applyTheme() {
        var saved = localStorage.getItem("theme") || "light";
        var root  = document.documentElement;
        if (saved === "dark") {
          root.classList.add("dark");
        } else if (saved === "system") {
          root.classList.toggle(
            "dark",
            window.matchMedia("(prefers-color-scheme: dark)").matches
          );
        } else {
          root.classList.remove("dark");
        }
      }

      // Run immediately (before paint)
      __applyTheme();

      // Re-run after every Astro client-side navigation swap
      // This is what fixes the "need to refresh" bug.
      document.addEventListener("astro:after-swap", __applyTheme);
    </script>

    <ClientRouter />
  </head>
  <body class="antialiased">
    <slot />
      <!-- Floating Dock menu -->
      <div class="fixed bottom-10 left-0 right-0 flex justify-center z-50 pointer-events-none">
        <div class="pointer-events-auto">
          <FloatingDock client:load />
        </div>
      </div>
  </body>
</html>
